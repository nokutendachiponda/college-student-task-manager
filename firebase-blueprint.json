{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "profilePic": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "student"] },
        "lastActive": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Task": {
      "title": "Task",
      "description": "A task assigned to a user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "code": { "type": "string" },
        "time": { "type": "string" },
        "duration": { "type": "string" },
        "priority": { "type": "string", "enum": ["High", "Medium", "Low"] },
        "type": { "type": "string" },
        "color": { "type": "string" },
        "status": { "type": "string" },
        "dayIdx": { "type": "integer" },
        "courseId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "title", "dayIdx"]
    },
    "Course": {
      "title": "Course",
      "description": "A course a user is enrolled in",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "code": { "type": "string" },
        "progress": { "type": "number" },
        "status": { "type": "string" },
        "color": { "type": "string" }
      },
      "required": ["id", "userId", "name", "code"]
    },
    "Broadcast": {
      "title": "Broadcast",
      "description": "System-wide message from admin",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "message": { "type": "string" },
        "senderId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "message", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/tasks/{taskId}": {
      "schema": "Task",
      "description": "Individual task documents"
    },
    "/courses/{courseId}": {
      "schema": "Course",
      "description": "Individual course documents"
    },
    "/broadcasts/{broadcastId}": {
      "schema": "Broadcast",
      "description": "System-wide broadcast messages"
    }
  }
}
